# Copy this to .env and fill in your key — then `make demo` just works.
# Either key works. OpenRouter is used first if both are set.

# OpenRouter (proxies Claude + 200 other models — openrouter.ai):
OPENROUTER_API_KEY=sk-or-...

# Anthropic direct (optional, used if OPENROUTER_API_KEY not set):
# ANTHROPIC_API_KEY=sk-ant-...
